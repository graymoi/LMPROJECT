# Git 忽略文件配置

# 操作系统文件
.DS_Store
Thumbs.db
desktop.ini

# IDE 配置文件
.vscode/
.idea/
*.swp
*.swo
*~

# 临时文件
*.tmp
*.temp
*.log
*.bak

# 大文件（不同步）
项目库/项目资料/**/*
*.pdf
*.docx
*.doc
*.xlsx
*.xls
*.pptx
*.ppt

# 敏感信息
*.env
.env.local
.env.*.local
*.key
*.pem
credentials.json

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 临时工作文件夹
临时工作文件夹/**/*
!临时工作文件夹/.gitkeep

# 新闻监测历史
.trae/skills/新闻监测/history.json

# 优化临时文件
.trae/skills/任务编排/temp/**/*
!.trae/skills/任务编排/temp/.gitkeep
